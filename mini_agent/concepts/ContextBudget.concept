concept ContextBudget [Window, ThresholdPct, Reserve]
  purpose
    Monitor conversation size against a context window and trigger compaction when the threshold is crossed, using a two-pass strategy of snipping then summarization.

  state
    threshold: one Int
    needs_compaction: one Bool

  actions
    init (w: Window, pct: ThresholdPct, r: Reserve)
      post: threshold = w * pct - r; needs_compaction = false

    check (log: MessageLog)
      post: needs_compaction = (estimate_tokens(log.messages) >= threshold)

    maybe_compact (log: MessageLog)
      pre: needs_compaction
      post: snip old tool outputs in log (keep beginning + end); if still over threshold, summarize old turns via LLM; needs_compaction = false
